# ============================================================
# Trip Trailers — environment configuration
# Copy to ".env" and fill in. Provide the API key that matches MODEL.
# ============================================================

# --- Required: powers the agents ---
# Provide the key for whichever provider MODEL points at (only one needed).

# OpenRouter (default) — free models available.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini — only needed if MODEL is a gemini/* model.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Model (LiteLLM provider/model string used by CrewAI) ---
# Free OpenRouter options (suffix ":free"):
#   openrouter/deepseek/deepseek-chat-v3.1:free
#   openrouter/meta-llama/llama-3.3-70b-instruct:free
#   openrouter/google/gemini-2.0-flash-exp:free
# Gemini options: gemini/gemini-2.5-flash, gemini/gemini-2.5-pro, gemini/gemini-2.0-flash
MODEL=openrouter/deepseek/deepseek-chat-v3.1:free

# ------------------------------------------------------------
# Optional real-data integrations.
# If a key is missing, the matching tool falls back to built-in
# mock data so the whole app still runs end-to-end.
# ------------------------------------------------------------

# Web search — Tavily (https://tavily.com) is tried first, then Serper.
TAVILY_API_KEY=
SERPER_API_KEY=

# Weather — keyless via Open-Meteo by default.
# Set this only to upgrade to OpenWeather (https://openweathermap.org/api).
OPENWEATHER_API_KEY=

# --- Server ---
HOST=127.0.0.1
PORT=8000
